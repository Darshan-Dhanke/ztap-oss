# Copy to .env and adjust as needed. .env is gitignored.

# --- Postgres (the "compute") ---
POSTGRES_USER=ztap
POSTGRES_PASSWORD=ztap
POSTGRES_DB=ztap

# --- MinIO (lakehouse object store) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
WAREHOUSE_BUCKET=warehouse

# --- Base image overrides (optional) ---
# By default the stack pulls upstream images. To pin to your own mirrored copies
# (see scripts/mirror_images.sh), uncomment and point these at your namespace:
# POSTGRES_IMAGE=darshandhanke07/ztap-postgres:16
# MINIO_IMAGE=darshandhanke07/ztap-minio:latest
# MC_IMAGE=darshandhanke07/ztap-minio-mc:latest
# UC_IMAGE=darshandhanke07/ztap-unity-catalog:latest
# KAFKA_IMAGE=darshandhanke07/ztap-kafka:3.8.0
# CONNECT_IMAGE=darshandhanke07/ztap-debezium-connect:2.7.3.Final
